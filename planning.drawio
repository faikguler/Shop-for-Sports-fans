    <diagram id="_s3jRCY8IlPaTvBFReEo" name="Page-1">
        <mxGraphModel dx="727" dy="330" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="2" value="Matchday Market/Fandrop/KitBid&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div&gt;MVP - a fan can register, browse, list?? and express intent to purchase, all within a clean sports themed UI&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="230" y="10" width="350" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="QBmttzjRbXvEFquqEaty-13" value="The Problem" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="20" y="170" width="100" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="QBmttzjRbXvEFquqEaty-15" value="Sport fans are passionate, loyal and consistent buyers yet the market fails them. There is no single trusted destination specifically for sport fans to buy sell and discover gear" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="190" y="140" width="250" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="QBmttzjRbXvEFquqEaty-17" value="&lt;b&gt;Trust and authenticity&lt;/b&gt; - counterfit shirts&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;b&gt;Disunited market&lt;/b&gt; - fans use ebay, facebook marketplace, reddit, club websites. there is no single trusted destination built for sport fans&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;b&gt;No community&lt;/b&gt; - selling a match worn kit carries a story but some platforms strip that out, it just becomes a product, not a piece of sports history???&lt;br&gt;&lt;/font&gt;&lt;/font&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="510" y="140" width="290" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="QBmttzjRbXvEFquqEaty-18" value="The solution" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="10" y="370" width="110" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="QBmttzjRbXvEFquqEaty-19" value="[website name] is a sports fan website where fans can purchase sport merchandise, tickets, and list?? items filtered by team, sport etc" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="180" y="325" width="250" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="QBmttzjRbXvEFquqEaty-20" value="&lt;b&gt;fan filtering&lt;/b&gt; - browse by sport, team,&amp;nbsp;&lt;div&gt;&lt;b&gt;community trust system&lt;/b&gt; - buyer ratings?&lt;/div&gt;&lt;div&gt;&lt;b&gt;clean modern UI&lt;/b&gt; - a shopping experience that feels modern&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="510" y="320" width="250" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="udOeafpgu6XVYhNr2s3o-2" value="" style="endArrow=classic;startArrow=classic;html=1;" parent="1" edge="1">
                    <mxGeometry width="50" height="50" relative="1" as="geometry">
