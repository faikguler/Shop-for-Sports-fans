    <diagram id="d6zkHYhs7E5bBBJaSN6z" name="Page-2">
        <mxGraphModel dx="727" dy="330" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="Hb051D1MtKHeKxV40aO9-1" value="1 - Login/Register&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;b&gt;Register&lt;/b&gt; - new user creates account with name, email, password, fav team?&lt;/div&gt;&lt;div&gt;&lt;b&gt;Login&lt;/b&gt; - logs in with email and password&lt;/div&gt;&lt;div&gt;Logout - session cleared&lt;/div&gt;&lt;div&gt;&lt;b&gt;Profile page&lt;/b&gt; - shows username and date joined&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="10" width="290" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="nG9ExTN6iJS7m8yLQxU0-1" value="2 - Search Listings&lt;div&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(63, 63, 63); background-color: transparent;&quot;&gt;&lt;b&gt;Search bar&lt;/b&gt; - text search&amp;nbsp;&lt;/span&gt;&lt;div&gt;&lt;b&gt;Browse all&lt;/b&gt; - list of all listings, title, price, image, condition, team ?&lt;/div&gt;&lt;div&gt;&lt;b&gt;Filter: Sport&lt;/b&gt; - maybe dropdown menu, football, basketball, rugby&lt;/div&gt;&lt;div&gt;&lt;b&gt;Filter: Team&lt;/b&gt; - dropdown with listing data&lt;/div&gt;&lt;div&gt;Filter Category - shirt&lt;/div&gt;&lt;div&gt;&lt;b&gt;Sort:&lt;/b&gt; - Price whether high-low low-high&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="10" width="370" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="sMWr7mb4GEJBnoJNbfAw-1" value="3 - View Listing&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;b&gt;Detail page &lt;/b&gt;- description, images, title, price&lt;/div&gt;&lt;div&gt;&lt;b&gt;Buy button&lt;/b&gt; - users can add product to cart&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="200" width="260" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="AzYoWYx52eRNZk3OGMjv-1" value="4 - Checkout&amp;nbsp;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;b&gt;Add to cart&lt;/b&gt; - buyer adds item to cart, count shown in navbar&lt;/div&gt;&lt;div&gt;&lt;b&gt;Cart page &lt;/b&gt;- List of items, amount of items and total price&lt;/div&gt;&lt;div&gt;Checkout form - order summary&lt;/div&gt;&lt;div&gt;&lt;b&gt;Order confirmation &lt;/b&gt;- confirms purchase request, seller notified&lt;/div&gt;&lt;div&gt;&lt;b&gt;Sold&lt;/b&gt; - listing is marked as sold and removed from browser&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="400" y="187.5" width="355" height="165" as="geometry"/>
                </mxCell>
                <mxCell id="5W81xECZfQPzj0S7f3VQ-1" value="Buyer stories&amp;nbsp;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="340" y="390" width="110" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="uOIHmRs4fpkiOk5Q32U6-1" value="User story&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div&gt;1 - As a fan, I want to browse orders so i can find items for sale&lt;/div&gt;&lt;/div&gt;&lt;div&gt;2 - as a fan i want to search by team name so i can get relevant items quickly&lt;/div&gt;&lt;div&gt;3- as a buyer i want to view a listing page so i can see details and photos before buying&lt;/div&gt;&lt;div&gt;4 - as a buyer i want to add an item to my cart so i can review booking&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="4" y="440" width="366" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="XrIiv57gFCgR9zzLgTiL-1" value="Acceptance Criteria&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1 - Listings visible on homepage without login&lt;/div&gt;&lt;div&gt;2 - the search return only matching team listings&lt;/div&gt;&lt;div&gt;3 - clicking order/list opens detail page with all fields&lt;/div&gt;&lt;div&gt;4 - updates cart with item&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="415" y="440" width="345" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="vU7MVHHxAFoCc9CDujYi-1" value="Admin Story" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="320" y="680" width="105" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="TEl7HmkR3c19E0vNvjoh-1" value="User story&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;as a admin i want to see all registered users so i can monitor the platform&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="740" width="280" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="HHund8jCoiqu8PqZiVQP-1" value="Acceptance Criteria&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1 - User/users list visible in admin panel&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="425" y="740" width="270" height="150" as="geometry"/>
